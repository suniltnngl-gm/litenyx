@@ -1683,6 +1685,25 @@ bool DisconnectBlock(const CBlock& block, CValidationState& state, const CBlockI
         }
     }
 
+    // Litenyx Phase 2: roll back exactly the global shared-state transitions this
+    // block introduced, so reorgs undo prior history before new history applies.
+    LitenyxDisconnectSharedState(block);
+
+    // Litenyx Phase 3: roll back any topology transition this block recorded, so
+    // a reorg across a split/merge boundary restores the prior N_h deterministically.
+    {
+        uint8_t nChainId = block.nyx_aux.chainId;
+        int nFull = 0;
+        if (nChainId < LITENYX_TOPO_MAX_CHAINS) {
+            int64_t sz = (int64_t)::GetSerializeSize(block, SER_DISK, CLIENT_VERSION);
+            int64_t maxsz = (int64_t)LitenyxChainParamsFor(nChainId).nMaxBlockSize;
+            if (maxsz > 0) nFull = (int)(100LL * sz / maxsz);
+            if (nFull > 100) nFull = 100;
+            if (nFull < 0) nFull = 0;
+        }
+        LitenyxTopologyTracker::Instance().Disconnect(nChainId, pindex->nHeight, nFull);
+    }
+
     // move best block pointer to prevout block
     view.SetBestBlock(pindex->pprev->GetBlockHash());
 
@@ -2033,6 +2054,34 @@ bool ConnectBlock(const CBlock& block, CValidationState& state, CBlockIndex* pin
     // add this block to the view's block chain
     view.SetBestBlock(pindex->GetBlockHash());
 
+    // Litenyx Phase 2: validate the aux header (chainId lane + same-chain anchor)
+    // then enforce the global shared spent-set across all chains. A cross-chain
+    // double spend (same outpoint on a different chainId) is rejected here.
+    if (!LitenyxCheckAuxHeader(block, pindex->pprev, state)) {
+        return false;
+    }
+    if (!LitenyxConnectSharedState(block, state)) {
+        return false;
+    }
+
+    // Litenyx Phase 3: advance the topology tracker from this block's canonical
+    // data. The tracker reads the block's fullness vs its chain's max block size
+    // and, at observation boundaries, may SPLIT/MERGE. All math is delegated to
+    // LITENYX_topology.h (single source of truth). Rollback happens in
+    // DisconnectBlock below.
+    {
+        uint8_t nChainId = block.nyx_aux.chainId;
+        int nFull = 0;
+        if (nChainId < LITENYX_TOPO_MAX_CHAINS) {
+            int64_t sz = (int64_t)::GetSerializeSize(block, SER_DISK, CLIENT_VERSION);
+            int64_t maxsz = (int64_t)LitenyxChainParamsFor(nChainId).nMaxBlockSize;
+            if (maxsz > 0) nFull = (int)(100LL * sz / maxsz);
+            if (nFull > 100) nFull = 100;
+            if (nFull < 0) nFull = 0;
+        }
+        LitenyxTopologyTracker::Instance().Connect(nChainId, pindex->nHeight, nFull);
+    }
+
     int64_t nTime5 = GetTimeMicros(); nTimeIndex += nTime5 - nTime4;
     LogPrint("bench", "    - Index writing: %.2fms [%.2fs]\n", 0.001 * (nTime5 - nTime4), nTimeIndex * 0.000001);
 
