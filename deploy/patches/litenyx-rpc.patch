+/** Litenyx Phase 3 regtest-only RPC: exercise the REAL topology tracker (the
+ *  same module ConnectBlock/DisconnectBlock use) to prove the invariant
+ *    forall N,  Spend(U, C_i) => NOT Spend(U, C_j)   (i != j)
+ *  survives split/merge, and that bounds/cooldown/rollback are deterministic.
+ *
+ *  Modes:
+ *    status            -> {nChains, lastTransition}
+ *    observe <c> <mc>  -> feed a synthetic load mc (0..100) for chainId c
+ *    tick <height>     -> finalize the current window at observation boundary
+ *    reset             -> clear tracker state back to N = LITENYX_MIN_CHAINS
+ *
+ *  All decision math is delegated to LITENYX_topology.h (single source of truth).
+ *  This RPC is regtest-only and is NOT a consensus dependency.
+ */
+UniValue testlitenyxtopology(const JSONRPCRequest& request)
+{
+    auto litenyxGetInt = [](const UniValue& v) -> int {
+        if (v.isNum()) return v.get_int();
+        return atoi(v.get_str().c_str());
+    };
+    try {
+        if (request.fHelp || request.params.size() < 1)
+            throw std::runtime_error(
+                "testlitenyxtopology \"mode\" [chainid] [mc] [height]\n"
+                "\nExercise the Litenyx global topology tracker used by ConnectBlock.\n"
+                "mode:    \"status\" | \"observe\" | \"tick\" | \"reset\"\n"
+                "chainid: 0..N-1 (for observe)\n"
+                "mc:      0..100 normalized load (for observe)\n"
+                "height:  observation boundary height (for tick)\n");
+
+        std::string mode = request.params[0].get_str();
+
+        if (mode == "status") {
+            UniValue out(UniValue::VOBJ);
+            out.pushKV("nChains", (int)LitenyxTopologyTracker::Instance().Chains());
+            out.pushKV("lastTransition", (int)LitenyxTopologyTracker::Instance().LastTransition());
+            out.pushKV("minChains", (int)LITENYX_MIN_CHAINS);
+            out.pushKV("maxChains", (int)LITENYX_TOPO_MAX_CHAINS);
+            return out;
+        } else if (mode == "observe") {
+            if (request.params.size() < 3)
+                throw JSONRPCError(RPC_INVALID_PARAMETER, "observe requires chainid and mc");
+            uint8_t c = (uint8_t)litenyxGetInt(request.params[1]);
+            int mc = litenyxGetInt(request.params[2]);
+            LitenyxTopologyTracker::Instance().Observe(c, mc);
+            UniValue out(UniValue::VOBJ);
+            out.pushKV("observed", true);
+            out.pushKV("chainid", (int)c);
+            out.pushKV("mc", mc);
+            return out;
+        } else if (mode == "tick") {
+            if (request.params.size() < 2)
+                throw JSONRPCError(RPC_INVALID_PARAMETER, "tick requires height");
+            uint32_t h = (uint32_t)litenyxGetInt(request.params[1]);
+            LitenyxTopologyTracker::Instance().Tick(h);
+            UniValue out(UniValue::VOBJ);
+            out.pushKV("nChains", (int)LitenyxTopologyTracker::Instance().Chains());
+            out.pushKV("lastTransition", (int)LitenyxTopologyTracker::Instance().LastTransition());
+            return out;
+        } else if (mode == "reset") {
+            LitenyxTopologyTracker::Instance().Reset();
+            UniValue out(UniValue::VOBJ);
+            out.pushKV("reset", true);
+            out.pushKV("nChains", (int)LitenyxTopologyTracker::Instance().Chains());
+            return out;
+        } else {
+            throw JSONRPCError(RPC_INVALID_PARAMETER, "unknown mode (status|observe|tick|reset)");
+        }
+    } catch (const std::exception& e) {
+        throw JSONRPCError(RPC_MISC_ERROR, std::string("LITENYX-topology: ") + e.what());
+    }
+}
