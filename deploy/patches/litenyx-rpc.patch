+/** Litenyx Phase 4B(4) regtest-only RPC: exercise the REAL consensus-authority
+ *  decision (regime -> derive expected T_h from a CANONICAL synthetic chain ->
+ *  pure VerifyTopologyCommitment) that ConnectBlock enforces. This drives the
+ *  actual compiled engine (LITENYX_topology_authority.h) so the Python harness
+ *  can assert the activation-boundary matrix, path-independence, and
+ *  reorg-truncation WITHOUT a V2-commitment-aware miner (block production is a
+ *  separate scope). It creates NO process-local state and is NOT a consensus
+ *  dependency.
+ *
+ *  Deterministic synthetic canonical chain: `height` blocks, all on chain 0 at
+ *  half MAX_BLOCK_WEIGHT (a pure function of height), matching the C++ proofs.
+ *
+ *  Modes:
+ *    regime <net> <height>
+ *        -> {regime}                                  (Pre/Soft/Hard)
+ *    expected <net> <height>
+ *        -> {commitment}   TopologyStateHash(expected T_h) hex
+ *    decide <net> <height> <present:0|1> <commitmentHex>
+ *        -> {verdict}      "valid" | "invalid" | "advisory_mismatch"
+ */
+UniValue testlitenyxtopoauthority(const JSONRPCRequest& request)
+{
+    auto getInt = [](const UniValue& v) -> long {
+        if (v.isNum()) return (long)v.get_int64();
+        return atol(v.get_str().c_str());
+    };
+    auto buildChain = [](uint32_t h) {
+        std::vector<LitenyxCommittedBlock> v(h);
+        for (auto& b : v) { b.chainId = 0; b.blockWeight = LITENYX_MAX_BLOCK_WEIGHT / 2; }
+        return v;
+    };
+    auto regimeName = [](LitenyxTopoRegime r) -> std::string {
+        switch (r) {
+            case LitenyxTopoRegime::PreDerivation: return "PreDerivation";
+            case LitenyxTopoRegime::SoftAdvisory:  return "SoftAdvisory";
+            case LitenyxTopoRegime::HardAuthority: return "HardAuthority";
+        }
+        return "unknown";
+    };
+    try {
+        if (request.fHelp || request.params.size() < 3)
+            throw std::runtime_error(
+                "testlitenyxtopoauthority \"mode\" \"net\" height [arg4] [arg5]\n"
+                "\nExercise the Litenyx consensus-authority topology decision.\n"
+                "mode:   \"regime\" | \"expected\" | \"decide\"\n"
+                "net:    \"main\" | \"test\" | \"regtest\"\n"
+                "height: block height to evaluate at\n"
+                "decide: arg4=present(0|1), arg5=commitment hex\n");
+
+        std::string mode = request.params[0].get_str();
+        std::string net = request.params[1].get_str();
+        uint32_t height = (uint32_t)getInt(request.params[2]);
+        LitenyxTopoActivation act = LitenyxTopoActivationForNetwork(net);
+
+        if (mode == "regime") {
+            UniValue out(UniValue::VOBJ);
+            out.pushKV("regime", regimeName(act.RegimeAt(height)));
+            return out;
+        }
+
+        LitenyxTopologyState expected = LitenyxCalculateExpectedTopologyFromChain(
+            LitenyxTopologyState::Genesis(), buildChain(height), height);
+
+        if (mode == "expected") {
+            UniValue out(UniValue::VOBJ);
+            out.pushKV("commitment",
+                       LitenyxExpectedTopologyCommitment(expected).GetHex());
+            out.pushKV("nChains", (int)expected.nN);
+            return out;
+        } else if (mode == "decide") {
+            if (request.params.size() < 5)
+                throw JSONRPCError(RPC_INVALID_PARAMETER,
+                                   "decide requires present(0|1) and commitment hex");
+            bool present = getInt(request.params[3]) != 0;
+            uint256 carried = uint256S(request.params[4].get_str().c_str());
+            LitenyxCommitVerdict v = LitenyxVerifyTopologyCommitment(
+                act.RegimeAt(height), present, carried, expected);
+            UniValue out(UniValue::VOBJ);
+            const char* vs = (v == LitenyxCommitVerdict::Valid) ? "valid"
+                           : (v == LitenyxCommitVerdict::AdvisoryMismatch) ? "advisory_mismatch"
+                           : "invalid";
+            out.pushKV("verdict", vs);
+            out.pushKV("regime", regimeName(act.RegimeAt(height)));
+            return out;
+        } else {
+            throw JSONRPCError(RPC_INVALID_PARAMETER,
+                               "unknown mode (regime|expected|decide)");
+        }
+    } catch (const std::exception& e) {
+        throw JSONRPCError(RPC_MISC_ERROR, std::string("LITENYX-topoauthority: ") + e.what());
+    }
+}
